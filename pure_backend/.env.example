APP_NAME=Medical Governance API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=medical_governance
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/medical_governance

JWT_ISSUER=medical-governance-api
JWT_AUDIENCE=medical-governance-clients
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_SECRET_KEY=replace-with-strong-random-secret
JWT_ALGORITHM=HS256

ENCRYPTION_KEY=replace-with-32-byte-base64-value
MAX_UPLOAD_SIZE_MB=20
DEFAULT_SLA_HOURS=48
REMINDER_LEAD_HOURS=1
ENFORCE_HTTPS=true
TRUSTED_PROXY_HEADERS=true
TRUSTED_PROXIES=127.0.0.1,::1
